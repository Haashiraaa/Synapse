

# ── Telegram ──────────────────────────────────────────────
# Get this from @BotFather on Telegram after creating a bot
TELEGRAM_TOKEN=

# Your bot's username, including the @ omitted or included — just be consistent
# e.g. MyGroupBot (not @MyGroupBot)
BOT_USERNAME=

# The chat_id of the ONE group this bot is allowed to respond in.
# Add your bot to the group, send a message, then check:
# https://api.telegram.org/bot<TELEGRAM_TOKEN>/getUpdates
GROUP_CHAT_ID=

# ── Anthropic ─────────────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Only "claude" is implemented right now
AI_PROVIDER=claude

# ── Database ──────────────────────────────────────────────
# Postgres connection string, e.g.
# postgresql://user:password@localhost:5432/synapse
DATABASE_URL=

# ── Optional tuning ───────────────────────────────────────
# How many messages to keep in the sliding context window before summarising
MESSAGE_WINDOW=20

# ── Optional: email alerts on bot start/stop/error ────────
# Leave blank to disable alerts entirely
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_PASSWORD=
